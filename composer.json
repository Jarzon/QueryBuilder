{
  "name": "jarzon/querybuilder",
  "description": "A Query Builder",
  "type": "project",
  "config": {
    "bin-dir": "bin",
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },
  "autoload": {
    "psr-4": {"Jarzon\\QueryBuilder\\": "src/"}
  },
  "autoload-dev": {
    "psr-4": {"Jarzon\\QueryBuilder\\Tests\\": "tests/"}
  },
  "require": {
    "php": ">=8.4.0"
  },
  "require-dev": {
    "phpunit/phpunit": "~13.0.6",
    "brianium/paratest": "^7.14",
    "phpstan/phpstan": "~2.1",
    "phpstan/extension-installer": "^1.4.0",
    "phpstan/phpstan-deprecation-rules": "^2.0.0"
  }
}
